rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ストーリーボードデータ: ユーザーは自分のデータのみアクセス可能
    match /storyboards/{userId}/projects/{projectId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // データバリデーション
      allow create: if request.auth != null 
        && request.auth.uid == userId
        && request.resource.data.keys().hasAll(['name', 'pages', 'createdAt', 'updatedAt', 'createdBy', 'version'])
        && request.resource.data.createdBy == userId
        && request.resource.data.version is number;
      
      allow update: if request.auth != null 
        && request.auth.uid == userId
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.version > resource.data.version;
    }
    
    // 他のすべてのドキュメントへのアクセスを拒否
    match /{document=**} {
      allow read, write: if false;
    }
  }
}